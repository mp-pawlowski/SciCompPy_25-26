# Create the function print_working_days(date1, date2), where
# date1 and date2 are strings of the form 'YYYY-MM-DD'.
# The function prints dates of working days (from Monday to Friday)
# in the given range, date2 is excluded.

import datetime

date1 = "2026-04-01"
date2 = "2026-05-01"

def print_working_days(date1, date2):
    working_days = 0
    current_day = datetime.date.fromisoformat(date1)
    while current_day < datetime.date.fromisoformat(date2):
        if current_day.weekday() < 5:
            working_days += 1
        current_day += datetime.timedelta(days = 1)
    return working_days
